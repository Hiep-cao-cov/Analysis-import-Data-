"""Import analytics: volume (ton), supplier share, bar + pie, data table, optional upload."""
from __future__ import annotations

from pathlib import Path

import pandas as pd
import streamlit as st

from config.settings import DATA_DIR, DEFAULT_ANALYSIS_DATASET
from services.analysis_service import MONTH_ORDER, filter_options, prepare_analysis_frame
from services.data_loader_service import is_raw_customs_export, load_and_standardize
from ui.theme import CHART, dashboard_header

KG_PER_TON = 1000.0

TABLE_COLUMNS = [
    "year",
    "month",
    "quarter",
    "date",
    "supplier_group",
    "type",
    "type_clean",
    "material",
    "customer_name",
    "volume_ton",
    "total_usd",
    "unit_price",
    "country_origin",
    "hs_code",
    "description",
]


def _add_volume_ton(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()
    if "volume" in out.columns:
        out["volume_ton"] = pd.to_numeric(out["volume"], errors="coerce") / KG_PER_TON
    else:
        out["volume_ton"] = 0.0
    return out


def _order_months(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty or "month" not in df.columns:
        return df
    out = df.copy()
    out["_ord"] = out["month"].astype(str).str.lower().map(MONTH_ORDER)
    return out.sort_values("_ord").drop(columns="_ord")


def _ingest_file(source: Path, *, force_etl: bool) -> pd.DataFrame:
    df, _ = load_and_standardize(source, unit_filter="kg", force_etl=force_etl)
    return _add_volume_ton(prepare_analysis_frame(df))


def _load_default_data() -> pd.DataFrame | None:
    if not DEFAULT_ANALYSIS_DATASET.exists():
        return None
    return _ingest_file(DEFAULT_ANALYSIS_DATASET, force_etl=False)


def _get_dataframe() -> pd.DataFrame | None:
    return st.session_state.get("dashboard_df")


def _set_dataframe(df: pd.DataFrame, source_name: str):
    st.session_state.dashboard_df = df
    st.session_state.dashboard_source = source_name


def _monthly_volume_ton(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return pd.DataFrame(columns=["month", "volume_ton"])
    g = df.groupby("month", dropna=False)["volume_ton"].sum().reset_index()
    return _order_months(g)


def _supplier_share_same_material(
    df: pd.DataFrame,
    year: int,
    material_type: str,
    selected_supplier: str,
) -> tuple[pd.DataFrame, float, float]:
    """
    Share of selected supplier vs all suppliers for the same material type and year.
    Returns (pie dataframe, supplier tons, market tons).
    """
    type_col = "type_clean" if "type_clean" in df.columns else "material_type"
    base = df[(df["year"] == year) & (df[type_col] == material_type)]
    if base.empty:
        return pd.DataFrame(), 0.0, 0.0

    by_supplier = (
        base.groupby("supplier_group", dropna=False)["volume_ton"]
        .sum()
        .reset_index()
        .sort_values("volume_ton", ascending=False)
    )
    market_ton = float(by_supplier["volume_ton"].sum())
    row = by_supplier[by_supplier["supplier_group"] == selected_supplier]
    supplier_ton = float(row["volume_ton"].sum()) if not row.empty else 0.0

    pie_df = by_supplier.rename(columns={"supplier_group": "supplier", "volume_ton": "volume_ton"})
    pie_df["share_pct"] = (pie_df["volume_ton"] / market_ton * 100).round(1) if market_ton else 0.0
    return pie_df, supplier_ton, market_ton


def _volume_bar_chart(monthly: pd.DataFrame, title: str):
    if monthly.empty:
        st.info("No monthly volume for this selection.")
        return

    import plotly.express as px

    chart_df = monthly.copy()
    chart_df["month_label"] = chart_df["month"].astype(str).str.upper()

    fig = px.bar(
        chart_df,
        x="month_label",
        y="volume_ton",
        title=title,
        labels={"month_label": "Month", "volume_ton": "Volume (ton)"},
        color_discrete_sequence=[CHART["green"]],
        template="plotly_white",
    )
    fig.update_layout(
        height=400,
        margin=dict(l=20, r=20, t=44, b=20),
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        xaxis=dict(categoryorder="array", categoryarray=chart_df["month_label"].tolist()),
    )
    fig.update_yaxes(title="Volume (ton)", gridcolor="#F1F5F9")
    st.plotly_chart(fig, use_container_width=True)


def _share_pie_chart(pie_df: pd.DataFrame, selected_supplier: str, material_type: str, year: int):
    if pie_df.empty:
        st.info("No market data for this material type.")
        return

    import plotly.express as px

    fig = px.pie(
        pie_df,
        names="supplier",
        values="volume_ton",
        title=f"{material_type} volume share by supplier ({year})",
        hole=0.4,
        color_discrete_sequence=CHART["pie"],
    )
    fig.update_traces(
        textposition="inside",
        textinfo="percent+label",
        pull=[0.08 if s == selected_supplier else 0 for s in pie_df["supplier"]],
    )
    fig.update_layout(height=400, margin=dict(l=10, r=10, t=44, b=10))
    st.plotly_chart(fig, use_container_width=True)


def _render_upload_row():
    col_up, col_btn = st.columns([3, 1])
    with col_up:
        uploaded = st.file_uploader(
            "Upload your file (CSV / Excel) — optional",
            type=["csv", "xlsx", "xls"],
            key="dash_upload",
            label_visibility="collapsed",
        )
    with col_btn:
        use_default = st.button("Use default file", use_container_width=True)

    if uploaded is not None and st.session_state.get("dashboard_source") != uploaded.name:
        try:
            temp = DATA_DIR / f"_upload_{uploaded.name}"
            temp.write_bytes(uploaded.getvalue())
            preview = (
                pd.read_csv(temp, nrows=20, low_memory=False)
                if temp.suffix.lower() == ".csv"
                else pd.read_excel(temp, nrows=20)
            )
            force_etl = is_raw_customs_export(preview)
            with st.spinner("Processing file…"):
                df = _ingest_file(temp, force_etl=force_etl)
            _set_dataframe(df, uploaded.name)
            st.rerun()
        except Exception as e:
            st.error(f"Upload failed: {e}")

    if use_default:
        try:
            df = _load_default_data()
            if df is not None:
                _set_dataframe(df, DEFAULT_ANALYSIS_DATASET.name)
                st.rerun()
        except Exception as e:
            st.error(str(e))


def render_dashboard_page(set_active_df):
    if _get_dataframe() is None:
        try:
            df = _load_default_data()
            if df is not None:
                _set_dataframe(df, DEFAULT_ANALYSIS_DATASET.name)
        except Exception as e:
            st.error(f"Could not load default file: {e}")
            return

    _render_upload_row()

    df = _get_dataframe()
    if df is None:
        st.error(f"Place data in `{DEFAULT_ANALYSIS_DATASET.name}` or upload a file.")
        return

    set_active_df(df, st.session_state.get("dashboard_source", "data"))
    opts = filter_options(df)

    years = opts.get("years", [])
    suppliers = opts.get("suppliers", [])
    types = [t for t in opts.get("material_types", []) if str(t).strip() and str(t).lower() not in ("unspecified", "nan")]

    if not years:
        st.warning("No year column found in the file.")
        return
    if not suppliers:
        st.warning("No supplier information found in the file.")
        return
    if not types and "type_clean" in df.columns:
        types = sorted(df["type_clean"].dropna().unique().tolist(), key=str)

    dashboard_header("Import volume analysis")

    c1, c2, c3 = st.columns(3)
    with c1:
        year = st.selectbox("Year", years, index=len(years) - 1, key="dash_year")
    with c2:
        supplier = st.selectbox("Supplier", suppliers, key="dash_supplier")
    with c3:
        default_type = "PMDI" if "PMDI" in types else (types[0] if types else "")
        type_index = types.index(default_type) if default_type in types else 0
        material_type = st.selectbox("Material type (from file)", types, index=type_index, key="dash_mtype")

    year_int = int(year)
    type_col = "type_clean" if "type_clean" in df.columns else "material_type"
    filtered = df[
        (df["year"] == year_int)
        & (df["supplier_group"] == supplier)
        & (df[type_col] == material_type)
    ]

    pie_df, supplier_ton, market_ton = _supplier_share_same_material(
        df, year_int, material_type, supplier
    )
    share_pct = (supplier_ton / market_ton * 100) if market_ton > 0 else 0.0
    monthly = _monthly_volume_ton(filtered)

    m1, m2, m3 = st.columns(3)
    m1.metric("Supplier volume", f"{supplier_ton:,.2f} ton")
    m2.metric(f"Total {material_type} market", f"{market_ton:,.2f} ton")
    m3.metric("Share of material market", f"{share_pct:.1f}%")

    col_bar, col_pie = st.columns([1.2, 1])
    with col_bar:
        _volume_bar_chart(
            monthly,
            f"{supplier} — {material_type} volume by month ({year})",
        )
    with col_pie:
        _share_pie_chart(pie_df, supplier, material_type, year_int)
        st.caption(
            f"**{supplier}** accounts for **{share_pct:.1f}%** of all "
            f"**{material_type}** import volume in **{year}** (all suppliers combined)."
        )

    st.subheader("Detail data")
    if filtered.empty:
        st.warning("No rows for the selected year, supplier, and material type.")
    else:
        show_cols = [c for c in TABLE_COLUMNS if c in filtered.columns]
        table = filtered[show_cols].copy()
        if "date" in table.columns:
            table["date"] = pd.to_datetime(table["date"], errors="coerce").dt.strftime("%Y-%m-%d")
        if "volume_ton" in table.columns:
            table["volume_ton"] = table["volume_ton"].round(3)
        if "month" in table.columns:
            table["_ord"] = table["month"].astype(str).str.lower().map(MONTH_ORDER)
            table = table.sort_values("_ord").drop(columns="_ord")
        elif "date" in table.columns:
            table = table.sort_values("date")
        st.dataframe(table, use_container_width=True, hide_index=True, height=420)
